# ── SILXINE 备份脚本配置(复制为 .backup.env,不入库)──
#
# 待备份的 PostgreSQL 连接串。
#   - 本地 dev 库(测试/演练):postgresql://你的用户名@localhost:5432/silkmomo
#   - 生产库:必须先在 Zeabur「网络」给 postgresql 服务暴露公网端口,
#     再用那个 host:port 拼;不暴露则本机打不到内网 postgresql.zeabur.internal。
#     生产的"自动"备份请优先用 Zeabur 原生每日备份(见 docs/BACKUP.md)。
BACKUP_DATABASE_URL=

# 本地备份目录。建议放在 iCloud / Dropbox / 同步盘下,等于自动有了一份异地副本。
BACKUP_DIR=$HOME/Library/Mobile Documents/com~apple~CloudDocs/silxine-backups

# 可选:再额外复制一份到这里(第三份,3-2-1 里的另一处介质)
OFFSITE_DIR=

# 可选:gpg 公钥收件人邮箱/ID。设了就对备份加密(含密码哈希与资金流水,异地存放强烈建议)。
#   先 gpg --gen-key 生成密钥,gpg --list-keys 查收件人。
GPG_RECIPIENT=

# 轮转保留份数(GFS)
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=12
